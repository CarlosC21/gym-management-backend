datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. DEFINITIONS
enum Role {
  ADMIN
  MEMBER
}

enum PaymentStatus {
  PAID
  UNPAID
}

enum WodType {
  AMRAP
  FOR_TIME
  WEIGHT
  EMOM
  COMPLETION
}

// 2. MODELS
model User {
  id                 String         @id @default(uuid())
  email              String         @unique
  password           String
  mustChangePassword Boolean        @default(true)
  firstName          String
  lastName           String
  image              String?
  role               Role           @default(MEMBER)
  status             PaymentStatus  @default(UNPAID)
  nextDueDate        DateTime?
  createdAt          DateTime       @default(now())
  lastPaymentDate    DateTime?
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?      // Soft Delete

  mobilityPlans      MobilityPlan[]
  attendance         Attendance[]
  wodResults         WodResult[]
}

model Workout {
  id          String       @id @default(uuid())
  date        DateTime     @unique
  title       String?      // e.g., "Hera", "The Murph"
  description String?      @db.Text
  content     Json?        // Legacy support for older builders
  type        WodType      @default(COMPLETION)
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  attendance  Attendance[]
  wodResults  WodResult[]

  @@index([date])
}

model WodResult {
  id        String   @id @default(uuid())
  userId    String
  wodId     String
  
  // Score stored as string to handle 21:05, 12+5, or 100kg
  score     String
  rx        Boolean  @default(true)
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout   Workout  @relation(fields: [wodId], references: [id], onDelete: Cascade)

  @@unique([userId, wodId]) // One score per athlete per day
}

model Class {
  id          String       @id @default(uuid())
  startTime   String       // e.g., "05:15 AM"
  label       String?      // e.g., "Morning Grind"
  attendance  Attendance[]
}

model Attendance {
  id        String   @id @default(uuid())
  userId    String
  wodId     String
  classId   String   
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout   Workout  @relation(fields: [wodId], references: [id])
  class     Class    @relation(fields: [classId], references: [id])

  @@unique([userId, wodId]) 
}

model MobilityPlan {
  id        String   @id @default(uuid())
  userId    String
  name      String
  routine   Json     
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}