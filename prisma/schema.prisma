datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. DEFINITIONS (The missing pieces)
enum Role {
  ADMIN
  MEMBER
}

enum PaymentStatus {
  PAID
  UNPAID
}

// 2. MODELS
model User {
  id            String        @id @default(uuid())
  email         String        @unique
  password      String
  firstName     String
  lastName      String
  image         String?
  role          Role          @default(MEMBER)
  status        PaymentStatus @default(UNPAID)
  nextDueDate   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?     // Soft Delete

  enrollments   Enrollment[]
  mobilityPlans MobilityPlan[]
}

model Workout {
  id        String   @id @default(uuid())
  date      DateTime @unique
  content   Json     
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

model Class {
  id          String       @id @default(uuid())
  startTime   String       // e.g., "05:15 AM"
  label       String?      // e.g., "Morning Grind"
  enrollments Enrollment[]
}

model Enrollment {
  id        String   @id @default(uuid())
  userId    String
  classId   String
  date      DateTime // The specific day of the class
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  class     Class    @relation(fields: [classId], references: [id])

  // One class per day per member
  @@unique([userId, date]) 
}

model MobilityPlan {
  id        String   @id @default(uuid())
  userId    String
  name      String
  routine   Json     
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}